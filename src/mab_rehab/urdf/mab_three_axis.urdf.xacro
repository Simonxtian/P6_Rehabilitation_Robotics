<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mab_three_axis_rehab_robot">
  <!-- ========================================================================
       Bus / hardware-level parameters
       ======================================================================== -->
  <xacro:arg name="bus" default="SPI"/>
  <xacro:arg name="data_rate" default="1M"/>
  <xacro:arg name="use_pds" default="true"/>
  <xacro:arg name="use_regular_can_frames" default="false"/>
  <xacro:arg name="pds_id" default="100"/>
  <xacro:arg name="power_stage_socket" default="2"/>
  <xacro:arg name="fast_mode" default="false"/>
  <xacro:arg name="auto_enable_power_stage" default="true"/>
  <xacro:arg name="disable_power_stage_on_deactivate" default="false"/>
  <xacro:arg name="allow_no_connected_drives" default="true"/>
  <xacro:arg name="save_md_configuration_to_flash" default="false"/>
  <xacro:arg name="startup_in_idle_mode" default="true"/>
  <xacro:arg name="startup_reference_enabled" default="true"/>
  <xacro:arg name="safety_limits_enabled" default="true"/>
  <xacro:arg name="md_can_watchdog_ms" default="1000"/>
  <xacro:arg name="maintenance_reload_enabled" default="true"/>
  <xacro:arg name="maintenance_restore_controller" default="previous"/>
  <xacro:arg name="maintenance_service_timeout_ms" default="3000"/>

  <!-- ========================================================================
       Per-joint wiring + kinematics (the only geometry-bound args)
       Safety envelopes and PID gains are injected by the launch file
       from config/safety_limits.yaml, config/startup_reference.yaml, and
       config/pid_tuning.yaml. Motor tuning lives in config/motors/*.cfg.
       ======================================================================== -->
  <xacro:arg name="md_id_1" default="37"/>
  <xacro:arg name="md_id_2" default="940"/>
  <xacro:arg name="md_id_3" default="941"/>
  <xacro:arg name="md_config_1" default=""/>
  <xacro:arg name="md_config_2" default=""/>
  <xacro:arg name="md_config_3" default=""/>
  <xacro:arg name="gear_ratio_1" default="0.02857142857142857"/>
  <xacro:arg name="gear_ratio_2" default="0.1"/>
  <xacro:arg name="gear_ratio_3" default="0.1"/>
  <xacro:arg name="startup_reference_position_1" default="nan"/>
  <xacro:arg name="startup_reference_position_2" default="nan"/>
  <xacro:arg name="startup_reference_position_3" default="nan"/>
  <xacro:arg name="safety_position_min_1" default="-999.9"/>
  <xacro:arg name="safety_position_max_1" default="999.9"/>
  <xacro:arg name="safety_max_velocity_1" default="2000"/>
  <xacro:arg name="safety_max_acceleration_1" default="500.0"/>
  <xacro:arg name="safety_max_deceleration_1" default="500.0"/>
  <xacro:arg name="safety_max_torque_1" default="200.0"/>
  <xacro:arg name="position_pid_kp_1" default="42.0"/>
  <xacro:arg name="position_pid_ki_1" default="6.0"/>
  <xacro:arg name="position_pid_kd_1" default="0.0"/>
  <xacro:arg name="position_pid_windup_1" default="1.0"/>
  <xacro:arg name="velocity_pid_kp_1" default="2.0"/>
  <xacro:arg name="velocity_pid_ki_1" default="0.02"/>
  <xacro:arg name="velocity_pid_kd_1" default="0.0"/>
  <xacro:arg name="velocity_pid_windup_1" default="0.25"/>
  <xacro:arg name="impedance_kp_1" default="0.0"/>
  <xacro:arg name="impedance_kd_1" default="0.0"/>
  <xacro:arg name="motor_friction_1" default="0.1"/>
  <xacro:arg name="motor_stiction_1" default="0.1"/>
  <xacro:arg name="safety_position_min_2" default="-999.9"/>
  <xacro:arg name="safety_position_max_2" default="999.9"/>
  <xacro:arg name="safety_max_velocity_2" default="2000"/>
  <xacro:arg name="safety_max_acceleration_2" default="500.0"/>
  <xacro:arg name="safety_max_deceleration_2" default="500.0"/>
  <xacro:arg name="safety_max_torque_2" default="200.0"/>
  <xacro:arg name="position_pid_kp_2" default="28.0"/>
  <xacro:arg name="position_pid_ki_2" default="4.0"/>
  <xacro:arg name="position_pid_kd_2" default="0.0"/>
  <xacro:arg name="position_pid_windup_2" default="1.0"/>
  <xacro:arg name="velocity_pid_kp_2" default="4.8"/>
  <xacro:arg name="velocity_pid_ki_2" default="0.004"/>
  <xacro:arg name="velocity_pid_kd_2" default="0.0"/>
  <xacro:arg name="velocity_pid_windup_2" default="0.25"/>
  <xacro:arg name="impedance_kp_2" default="0.0"/>
  <xacro:arg name="impedance_kd_2" default="0.0"/>
  <xacro:arg name="motor_friction_2" default="0.1"/>
  <xacro:arg name="motor_stiction_2" default="0.1"/>
  <xacro:arg name="safety_position_min_3" default="-999.9"/>
  <xacro:arg name="safety_position_max_3" default="999.9"/>
  <xacro:arg name="safety_max_velocity_3" default="2000"/>
  <xacro:arg name="safety_max_acceleration_3" default="500.0"/>
  <xacro:arg name="safety_max_deceleration_3" default="500.0"/>
  <xacro:arg name="safety_max_torque_3" default="200.0"/>
  <xacro:arg name="position_pid_kp_3" default="21.0"/>
  <xacro:arg name="position_pid_ki_3" default="3.36"/>
  <xacro:arg name="position_pid_kd_3" default="0.0"/>
  <xacro:arg name="position_pid_windup_3" default="1.0"/>
  <xacro:arg name="velocity_pid_kp_3" default="3.6"/>
  <xacro:arg name="velocity_pid_ki_3" default="0.003"/>
  <xacro:arg name="velocity_pid_kd_3" default="0.0"/>
  <xacro:arg name="velocity_pid_windup_3" default="0.25"/>
  <xacro:arg name="impedance_kp_3" default="0.0"/>
  <xacro:arg name="impedance_kd_3" default="0.0"/>
  <xacro:arg name="motor_friction_3" default="0.1"/>
  <xacro:arg name="motor_stiction_3" default="0.1"/>

  <!-- Joint range limits (URDF schema requires these on revolute joints).
       Kept as xacro args so they can be overridden by the launch file if
       the safety envelope is narrower than the mechanical envelope. -->
  <xacro:arg name="joint_1_lower" default="-1.22173"/>
  <xacro:arg name="joint_1_upper" default="1.22173"/>
  <xacro:arg name="joint_1_effort" default="100"/>
  <xacro:arg name="joint_1_velocity" default="100"/>
  <xacro:arg name="joint_2_lower" default="-1.047198"/>
  <xacro:arg name="joint_2_upper" default="1.047198"/>
  <xacro:arg name="joint_2_effort" default="100"/>
  <xacro:arg name="joint_2_velocity" default="100"/>
  <xacro:arg name="joint_3_lower" default="-0.523599"/>
  <xacro:arg name="joint_3_upper" default="0.523599"/>
  <xacro:arg name="joint_3_effort" default="100"/>
  <xacro:arg name="joint_3_velocity" default="100"/>

  <!-- ========================================================================
       Visuals / materials
       ======================================================================== -->
  <material name="carbon"><color rgba="0.22 0.25 0.30 1.0"/></material>
  <material name="signal"><color rgba="0.85 0.43 0.14 1.0"/></material>
  <material name="silver"><color rgba="0.700 0.700 0.700 1.000"/></material>

  <link name="base_link">
    <inertial>
      <origin xyz="-0.0004893152259659719 -0.2513490561575862 -0.11283715805734928" rpy="0 0 0"/>
      <mass value="1.6888096724896144"/>
      <inertia ixx="0.011059" iyy="0.008847" izz="0.009341" ixy="-5e-06" iyz="0.001084" ixz="-9e-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find complete_system_urdf_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find complete_system_urdf_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="SP_1">
    <inertial>
      <origin xyz="-0.000157 0.127198 -0.096757" rpy="0 0 0"/>
      <mass value="0.7470"/>
      <inertia ixx="0.009477" ixy="+0.000007" ixz="+0.000004"
               iyy="0.008693" iyz="+0.003381" izz="0.004240"/>
    </inertial>
    <visual>
      <origin xyz="-0.0003 0.235996 -0.006391" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find complete_system_urdf_description)/meshes/SP_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.0003 0.235996 -0.006391" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find complete_system_urdf_description)/meshes/SP_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="FE_1">
    <inertial>
      <origin xyz="+0.015907 -0.014594 +0.066041" rpy="0 0 0"/>
      <mass value="0.5000"/>
      <inertia ixx="0.002095" ixy="-0.000326" ixz="-0.000239"
            iyy="0.003856" iyz="-0.000299" izz="0.002659"/>
    </inertial>
    <visual>
      <origin xyz="0.000339 0.001 0.190609" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find complete_system_urdf_description)/meshes/FE_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.000339 0.001 0.190609" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find complete_system_urdf_description)/meshes/FE_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="RU_1">
    <inertial>
      <origin xyz="-0.085404 +0.069009 -0.080129" rpy="0 0 0"/>
      <mass value="0.5350"/>
      <inertia ixx="0.001653" ixy="+0.000097" ixz="-0.000087" iyy="0.001705" iyz="+0.000042" izz="0.001788"/>
    </inertial>
    <visual>
      <origin xyz="-0.085661 0.001 -0.006391" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find complete_system_urdf_description)/meshes/RU_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.085661 0.001 -0.006391" rpy="0 0 0"/>
      <geometry>
        <mesh filename="file://$(find complete_system_urdf_description)/meshes/RU_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_1" type="revolute">
    <origin xyz="0.0003 -0.235996 0.006391" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="SP_1"/>
    <axis xyz="0.0 -1.0 0.0"/>
    <limit upper="1.22173" lower="-1.22173" effort="100" velocity="100"/>
  </joint>

  <joint name="joint_2" type="revolute">
    <origin xyz="-0.000639 0.234996 -0.197" rpy="0 0 0"/>
    <parent link="SP_1"/>
    <child link="FE_1"/>
    <axis xyz="0.0 0.0 -1.0"/>
    <limit upper="1.047198" lower="-1.047198" effort="100" velocity="100"/>
  </joint>

  <joint name="joint_3" type="revolute">
    <origin xyz="0.086 0.0 0.197" rpy="0 0 0"/>
    <parent link="FE_1"/>
    <child link="RU_1"/>
    <axis xyz="1.0 0.0 0.0"/>
    <limit upper="0.523599" lower="-0.523599" effort="100" velocity="100"/>
  </joint>

  <link name="tool0"/>
  <joint name="tool0_fixed" type="fixed">
    <parent link="RU_1"/>
    <child link="tool0"/>
    <origin xyz="-0.14 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================================
       ros2_control hardware definition
       ======================================================================== -->
  <ros2_control name="mab_hardware" type="system">
    <hardware>
      <plugin>mab_rehab/MABSystemHardware</plugin>
      <param name="bus">$(arg bus)</param>
      <param name="data_rate">$(arg data_rate)</param>
      <param name="use_pds">$(arg use_pds)</param>
      <param name="use_regular_can_frames">$(arg use_regular_can_frames)</param>
      <param name="pds_id">$(arg pds_id)</param>
      <param name="power_stage_socket">$(arg power_stage_socket)</param>
      <param name="fast_mode">$(arg fast_mode)</param>
      <param name="auto_enable_power_stage">$(arg auto_enable_power_stage)</param>
      <param name="disable_power_stage_on_deactivate">$(arg disable_power_stage_on_deactivate)</param>
      <param name="startup_in_idle_mode">$(arg startup_in_idle_mode)</param>
      <param name="allow_no_connected_drives">$(arg allow_no_connected_drives)</param>
      <param name="save_md_configuration_to_flash">$(arg save_md_configuration_to_flash)</param>
      <param name="startup_reference_enabled">$(arg startup_reference_enabled)</param>
      <param name="safety_limits_enabled">$(arg safety_limits_enabled)</param>
      <param name="md_can_watchdog_ms">$(arg md_can_watchdog_ms)</param>
      <param name="maintenance_reload_enabled">$(arg maintenance_reload_enabled)</param>
      <param name="maintenance_restore_controller">$(arg maintenance_restore_controller)</param>
      <param name="maintenance_service_timeout_ms">$(arg maintenance_service_timeout_ms)</param>
    </hardware>

    <joint name="joint_1">
      <param name="can_id">$(arg md_id_1)</param>
      <param name="config_path">$(arg md_config_1)</param>
      <param name="gear_ratio">$(arg gear_ratio_1)</param>
      <param name="startup_reference_position">$(arg startup_reference_position_1)</param>
      <param name="safety_position_min">$(arg safety_position_min_1)</param>
      <param name="safety_position_max">$(arg safety_position_max_1)</param>
      <param name="safety_max_velocity">$(arg safety_max_velocity_1)</param>
      <param name="safety_max_acceleration">$(arg safety_max_acceleration_1)</param>
      <param name="safety_max_deceleration">$(arg safety_max_deceleration_1)</param>
      <param name="safety_max_torque">$(arg safety_max_torque_1)</param>
      <param name="position_pid_kp">$(arg position_pid_kp_1)</param>
      <param name="position_pid_ki">$(arg position_pid_ki_1)</param>
      <param name="position_pid_kd">$(arg position_pid_kd_1)</param>
      <param name="position_pid_windup">$(arg position_pid_windup_1)</param>
      <param name="velocity_pid_kp">$(arg velocity_pid_kp_1)</param>
      <param name="velocity_pid_ki">$(arg velocity_pid_ki_1)</param>
      <param name="velocity_pid_kd">$(arg velocity_pid_kd_1)</param>
      <param name="velocity_pid_windup">$(arg velocity_pid_windup_1)</param>
      <param name="impedance_kp">$(arg impedance_kp_1)</param>
      <param name="impedance_kd">$(arg impedance_kd_1)</param>
      <param name="motor_friction">$(arg motor_friction_1)</param>
      <param name="motor_stiction">$(arg motor_stiction_1)</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="gear_ratio"/>
    </joint>

    <joint name="joint_2">
      <param name="can_id">$(arg md_id_2)</param>
      <param name="config_path">$(arg md_config_2)</param>
      <param name="gear_ratio">$(arg gear_ratio_2)</param>
      <param name="startup_reference_position">$(arg startup_reference_position_2)</param>
      <param name="safety_position_min">$(arg safety_position_min_2)</param>
      <param name="safety_position_max">$(arg safety_position_max_2)</param>
      <param name="safety_max_velocity">$(arg safety_max_velocity_2)</param>
      <param name="safety_max_acceleration">$(arg safety_max_acceleration_2)</param>
      <param name="safety_max_deceleration">$(arg safety_max_deceleration_2)</param>
      <param name="safety_max_torque">$(arg safety_max_torque_2)</param>
      <param name="position_pid_kp">$(arg position_pid_kp_2)</param>
      <param name="position_pid_ki">$(arg position_pid_ki_2)</param>
      <param name="position_pid_kd">$(arg position_pid_kd_2)</param>
      <param name="position_pid_windup">$(arg position_pid_windup_2)</param>
      <param name="velocity_pid_kp">$(arg velocity_pid_kp_2)</param>
      <param name="velocity_pid_ki">$(arg velocity_pid_ki_2)</param>
      <param name="velocity_pid_kd">$(arg velocity_pid_kd_2)</param>
      <param name="velocity_pid_windup">$(arg velocity_pid_windup_2)</param>
      <param name="impedance_kp">$(arg impedance_kp_2)</param>
      <param name="impedance_kd">$(arg impedance_kd_2)</param>
      <param name="motor_friction">$(arg motor_friction_2)</param>
      <param name="motor_stiction">$(arg motor_stiction_2)</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="gear_ratio"/>
    </joint>

    <joint name="joint_3">
      <param name="can_id">$(arg md_id_3)</param>
      <param name="config_path">$(arg md_config_3)</param>
      <param name="gear_ratio">$(arg gear_ratio_3)</param>
      <param name="startup_reference_position">$(arg startup_reference_position_3)</param>
      <param name="safety_position_min">$(arg safety_position_min_3)</param>
      <param name="safety_position_max">$(arg safety_position_max_3)</param>
      <param name="safety_max_velocity">$(arg safety_max_velocity_3)</param>
      <param name="safety_max_acceleration">$(arg safety_max_acceleration_3)</param>
      <param name="safety_max_deceleration">$(arg safety_max_deceleration_3)</param>
      <param name="safety_max_torque">$(arg safety_max_torque_3)</param>
      <param name="position_pid_kp">$(arg position_pid_kp_3)</param>
      <param name="position_pid_ki">$(arg position_pid_ki_3)</param>
      <param name="position_pid_kd">$(arg position_pid_kd_3)</param>
      <param name="position_pid_windup">$(arg position_pid_windup_3)</param>
      <param name="velocity_pid_kp">$(arg velocity_pid_kp_3)</param>
      <param name="velocity_pid_ki">$(arg velocity_pid_ki_3)</param>
      <param name="velocity_pid_kd">$(arg velocity_pid_kd_3)</param>
      <param name="velocity_pid_windup">$(arg velocity_pid_windup_3)</param>
      <param name="impedance_kp">$(arg impedance_kp_3)</param>
      <param name="impedance_kd">$(arg impedance_kd_3)</param>
      <param name="motor_friction">$(arg motor_friction_3)</param>
      <param name="motor_stiction">$(arg motor_stiction_3)</param>
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <state_interface name="voltage"/>
      <state_interface name="gear_ratio"/>
    </joint>
  </ros2_control>
</robot>
