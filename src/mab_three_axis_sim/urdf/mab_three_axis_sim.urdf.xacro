<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mab_three_axis_sim">
  <xacro:property name="joint_limit_min" value="-6.283"/>
  <xacro:property name="joint_limit_max" value="6.283"/>
  <xacro:property name="joint_max_velocity" value="20.0"/>
  <xacro:property name="joint_max_effort" value="40.0"/>

  <material name="carbon">
    <color rgba="0.22 0.25 0.30 1.0"/>
  </material>
  <material name="signal">
    <color rgba="0.85 0.43 0.14 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.18 0.12 0.04"/>
      </geometry>
      <material name="carbon"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.18 0.12 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <link name="link_1">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.18"/>
      </geometry>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <material name="signal"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.18"/>
      </geometry>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <origin xyz="0 0 0.09"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <link name="link_2">
    <visual>
      <geometry>
        <cylinder radius="0.022" length="0.16"/>
      </geometry>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <material name="signal"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.022" length="0.16"/>
      </geometry>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.08"/>
      <inertia ixx="0.0016" ixy="0.0" ixz="0.0" iyy="0.0016" iyz="0.0" izz="0.0008"/>
    </inertial>
  </link>

  <link name="link_3">
    <visual>
      <geometry>
        <cylinder radius="0.020" length="0.14"/>
      </geometry>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <material name="signal"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.020" length="0.14"/>
      </geometry>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.25"/>
      <origin xyz="0 0 0.07"/>
      <inertia ixx="0.0012" ixy="0.0" ixz="0.0" iyy="0.0012" iyz="0.0" izz="0.0006"/>
    </inertial>
  </link>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit
      lower="${joint_limit_min}"
      upper="${joint_limit_max}"
      effort="${joint_max_effort}"
      velocity="${joint_max_velocity}"/>
  </joint>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit
      lower="${joint_limit_min}"
      upper="${joint_limit_max}"
      effort="${joint_max_effort}"
      velocity="${joint_max_velocity}"/>
  </joint>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit
      lower="${joint_limit_min}"
      upper="${joint_limit_max}"
      effort="${joint_max_effort}"
      velocity="${joint_max_velocity}"/>
  </joint>

  <ros2_control name="mab_mock_system" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>

    <joint name="joint_1">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="joint_2">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>

    <joint name="joint_3">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity">
        <param name="initial_value">0.0</param>
      </state_interface>
    </joint>
  </ros2_control>
</robot>
